# ---- Core ----
SECRET_KEY=replace-with-a-long-random-string
DATABASE_URL=sqlite:///./nivaas.db        # or postgresql://user:pass@host:5432/nivaas
UPLOAD_DIR=uploads
TOKEN_EXPIRE_HOURS=24

# ---- Overdue detection (default threshold; admin can change it in the UI) ----
OVERDUE_DAYS=7

# ---- Seeded admin account (created on first startup) ----
ADMIN_NAME=Society Admin
ADMIN_EMAIL=admin@nivaas-society.com
ADMIN_PASSWORD=admin123

# ---- Email (any free SMTP: Brevo, Gmail app password, Mailtrap) ----
# Leave SMTP_HOST empty to print emails to the console instead (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=notices@nivaas-society.com
